# PostgreSQL / PostGIS 数据库配置
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_db_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=vue_map_db

# 完整的连接 URL (这是代码最需要的)
DATABASE_URL=postgresql://your_db_user:your_db_password@localhost:5432/vue_map_db

# JWT 密钥保持不变
SECRET_KEY=replace_with_a_random_64_char_secret

# 智能搜索默认配置
SMART_SEARCH_PROVIDER=zhipu
SMART_SEARCH_MODEL=glm-4.5-air
SMART_SEARCH_BASE_URL=https://open.bigmodel.cn/api/paas/v4
SMART_SEARCH_API_KEY=
